rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Profiles, stats and credits document rule
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Subcollection: History Items
      match /history/{historyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Subcollection: Support Tickets
      match /tickets/{ticketId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Support a dummy check collection for connection testing
    match /test/{docId} {
      allow read, write: if true;
    }
  }
}
